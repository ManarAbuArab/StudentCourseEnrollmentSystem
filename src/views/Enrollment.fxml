<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="574.0" prefWidth="890.0"
            stylesheets="@../styles/EnrollmentStyle.css"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EnrollmentController">

    <left>
        <VBox prefHeight="529.0" prefWidth="318.0" spacing="15" styleClass="sidebar">

            <Label styleClass="logo" text="Student Course Enrollment" />

            <Separator />

            <Label styleClass="section-label" text="STUDENT" />
            <ComboBox fx:id="studentsCombobox" prefWidth="270.0"
                      promptText="Select a student..."
                      styleClass="input" />

            <Label styleClass="section-label" text="COURSE" />
            <ComboBox fx:id="coursesCombobox" prefWidth="270.0"
                      promptText="Select a course..."
                      styleClass="input" />

            <Label styleClass="section-label" text="ENROLLMENT DATE" />
            <DatePicker fx:id="enrollmentDate" prefWidth="270.0"
                        styleClass="input" />

            <Separator />

            <Label styleClass="section-label" text="ACTIONS" />

            <HBox spacing="8">
                <Button onAction="#viewHandle" prefHeight="28.0" prefWidth="63.0"
                        styleClass="btn-secondary" text="View" />

                <Button onAction="#addHandle" prefHeight="28.0" prefWidth="63.0"
                        styleClass="btn-primary" text="Add" />

                <Button onAction="#updateHandle" prefHeight="28.0" prefWidth="63.0"
                        styleClass="btn-success" text="Update" />

                <Button onAction="#deleteHandle" prefHeight="28.0" prefWidth="63.0"
                        styleClass="btn-danger" text="Delete" />
            </HBox>

            <HBox spacing="8">
                <Button onAction="#clearHandle" prefHeight="30.0" prefWidth="270.0"
                        styleClass="btn-outline" text="Clear Form" />
            </HBox>

        </VBox>
    </left>

    <center>
        <StackPane styleClass="content">
            <TableView fx:id="table" prefHeight="574.0" prefWidth="572.0"
                       styleClass="custom-table">
                <columns>
                    <TableColumn fx:id="enrollmentIdTC" prefWidth="120.0"
                                 text="ENROLLMENT ID" />

                    <TableColumn fx:id="studentIdTC" prefWidth="130.0"
                                 text="STUDENT ID" />

                    <TableColumn fx:id="courseIdTC" prefWidth="120.0"
                                 text="COURSE ID" />

                    <TableColumn fx:id="enrollmentDateTC" prefWidth="190.0"
                                 text="ENROLLMENT DATE" />
                </columns>
            </TableView>
        </StackPane>
    </center>

</BorderPane>
